    function renderIcons(){
      iconsLayer.innerHTML = "";
      ICONS.forEach(item=>{
        if(item.id !== "trash" && TRASH.some(t => t.id === item.id)) return;
        const el = createIconEl(item);
        iconsLayer.appendChild(el);
      });
    }
    renderIcons();

    function getTrashEl(){
      return iconsLayer.querySelector('.deskIcon[data-id="trash"]');
    }

    function isOverTrash(x, y){
      const trashEl = getTrashEl();
      if(!trashEl) return false;
      const r = trashEl.getBoundingClientRect();
      return (x >= r.left && x <= r.right && y >= r.top && y <= r.bottom);
    }

    function makeIconDraggable(el, item){
      let dragging = false;
      let offsetX = 0, offsetY = 0;

      const onPointerMove = (e)=>{
        if(!dragging) return;
        const x = e.clientX - offsetX;
        const y = e.clientY - offsetY;

        const deskRect = desktop.getBoundingClientRect();
        const maxX = deskRect.width - el.offsetWidth - 6;
        const maxY = deskRect.height - el.offsetHeight - 6;

        const nx = Math.max(6, Math.min(maxX, x));
        const ny = Math.max(6, Math.min(maxY, y));

        el.style.left = nx + "px";
        el.style.top = ny + "px";

        const trashEl = getTrashEl();
        if(trashEl && item.id !== "trash"){
          const over = isOverTrash(e.clientX, e.clientY);
          trashEl.classList.toggle("trashHover", over);
        }
      };

      const onPointerUp = (e)=>{
        if(!dragging) return;
        dragging = false;
        el.releasePointerCapture(e.pointerId);

        const trashEl = getTrashEl();
        if(trashEl) trashEl.classList.remove("trashHover");

        if(item.id !== "trash" && isOverTrash(e.clientX, e.clientY)){
          const rx = parseInt(el.style.left, 10) || item.x;
          const ry = parseInt(el.style.top, 10) || item.y;

          if(!TRASH.some(t => t.id === item.id)){
            TRASH.push({ id:item.id, label:item.label, icon:item.icon, restoreX: rx, restoreY: ry });
          }
          renderIcons();

          if(openWindows.has("recycle")){
            const { winEl } = openWindows.get("recycle");
            renderTrashList(winEl);
          }
          return;
        }

        const nx = parseInt(el.style.left, 10) || item.x;
        const ny = parseInt(el.style.top, 10) || item.y;
        item.x = nx; item.y = ny;
      };

      el.addEventListener("pointerdown", (e)=>{
        if(e.button !== 0) return;
        e.stopPropagation();
        selectIcon(el);

        dragging = true;
        const r = el.getBoundingClientRect();
        offsetX = e.clientX - r.left;
        offsetY = e.clientY - r.top;

        el.setPointerCapture(e.pointerId);
      });

      el.addEventListener("pointermove", onPointerMove);
      el.addEventListener("pointerup", onPointerUp);
      el.addEventListener("pointercancel", onPointerUp);
    }

    function renderTrashList(winEl){
      const list = winEl.querySelector("#trashList");
      if(!list) return;

      if(TRASH.length === 0){
        list.innerHTML = `<div class="muted" style="font-size:12px;">(Empty)</div>`;
        return;
      }

      list.innerHTML = TRASH.map(t => `
        <div class="menuItem" data-restore="${t.id}" style="border:1px solid rgba(0,0,0,.15); margin:6px 0; background:#fff;">
          <div class="menuIco" style="background:#f5f5f5;">${t.icon}</div>
          <div style="display:flex; flex-direction:column; gap:2px;">
            <div style="font-size:12px; font-weight:700; color:#000;">${t.label}</div>
            <div class="muted" style="font-size:11px;">Click to restore</div>
          </div>
        </div>
      `).join("");

      list.onclick = (e)=>{
        const row = e.target.closest("[data-restore]");
        if(!row) return;
        const id = row.getAttribute("data-restore");
        restoreFromTrash(id);
        renderTrashList(winEl);
      };
    }

    function restoreFromTrash(id){
      const idx = TRASH.findIndex(t => t.id === id);
      if(idx === -1) return;
      const t = TRASH.splice(idx, 1)[0];

      const icon = ICONS.find(i => i.id === id);
      if(icon){
        icon.x = t.restoreX ?? icon.x;
        icon.y = t.restoreY ?? icon.y;
      }
      renderIcons();
    }

    /* =========================================================
      Calculator logic
    ========================================================= */
    function attachCalculatorHandlers(winEl){
      const display = winEl.querySelector("#calcDisplay");
      const root = winEl.querySelector("#calcRoot");
      if(!display || !root) return;

      let expr = "";
      let lastWasEq = false;

      const safeEval = (s)=>{
        const cleaned = s
          .replace(/%/g, "/100")
          .replace(/[^\d+\-*/().\s]/g, "");
        return Function("return (" + cleaned + ")")();
      };

      const setDisp = (v)=>{
        const str = String(v);
        display.textContent = str.length > 18 ? str.slice(0,18) : str;
      };

      const press = (k)=>{
        if(k === "C"){
          expr = "";
          lastWasEq = false;
          setDisp(0);
          return;
        }
        if(k === "⌫"){
          expr = expr.slice(0, -1);
          lastWasEq = false;
          setDisp(expr || 0);
          return;
        }
        if(k === "="){
          if(!expr) return;
          try{
            const res = safeEval(expr);
            expr = String(res);
            lastWasEq = true;
            setDisp(expr);
          }catch{
            expr = "";
            lastWasEq = false;
            setDisp("Error");
          }
          return;
        }

        const isOp = ["+","-","*","/"].includes(k);

        if(lastWasEq && !isOp){
          expr = "";
        }
        lastWasEq = false;

        if(isOp && expr && ["+","-","*","/"].includes(expr.slice(-1))){
          expr = expr.slice(0, -1) + k;
        } else {
          expr += k;
        }
        setDisp(expr);
      };

      root.addEventListener("click", (e)=>{
        const b = e.target.closest(".calcBtn");
        if(!b) return;
        press(b.getAttribute("data-k"));
      });

      winEl.addEventListener("keydown", (e)=>{
        const key = e.key;
        if((key >= "0" && key <= "9") || ["+","-","*","/","."].includes(key)){
          press(key);
          e.preventDefault();
        } else if(key === "Enter"){
          press("=");
          e.preventDefault();
        } else if(key === "Backspace"){
          press("⌫");
          e.preventDefault();
        } else if(key.toLowerCase() === "c"){
          press("C");
          e.preventDefault();
        } else if(key === "%"){
          press("%");
          e.preventDefault();
        }
      });
    }

    window.KEANU_OPEN = (id)=>{
      const mod = MODULES[id];
      if(mod) openApp(mod);
    };
  </script>
</body>
