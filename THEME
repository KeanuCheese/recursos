<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
  <title>{Title}</title>

  <style>
    :root{
      /* INTRO (requested RAW) */
      --intro-bg: url("https://raw.githubusercontent.com/KeanuCheese/Theme-K/05b4cb69a1d7915199918635767714e3fcd53605/Fondo_intro");
      --intro-win: url("https://raw.githubusercontent.com/KeanuCheese/Theme-K/05b4cb69a1d7915199918635767714e3fcd53605/Imagen%20intro");

      /* OS wallpaper (UPDATED requested RAW) */
      --os-wallpaper: url("https://raw.githubusercontent.com/KeanuCheese/Theme-K/b89546ac5c77afc7d6f8aba43af1cde396caa31c/brokensc-1536x864.jpg");

      /* Win95 palette */
      --w95-face: #c0c0c0;
      --w95-title: #000080;
      --w95-title2: #1084d0;
      --w95-text: #000;
      --w95-dark: #000000;
      --w95-mid: #808080;
      --w95-light: #ffffff;
      --w95-hilight: #dfdfdf;

      --shadow: 0 18px 60px rgba(0,0,0,.55);
      --font: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono","Courier New", monospace;
    }

    *{ box-sizing:border-box; }
    html,body{ height:100%; }
    body{
      margin:0;
      font-family: var(--font);
      background:#0b0b0d;
      color:#eaeaf2;
      overflow:hidden;
    }

    /* =========================================================
       Tumblr controls: invisible + top-left (requested)
    ========================================================= */
    iframe.tmblr-iframe,
    .tmblr-iframe,
    .tmblr-iframe--controls,
    .tmblr-iframe--app{
      position: fixed !important;
      top: 8px !important;
      left: 8px !important;
      right: auto !important;
      bottom: auto !important;
      opacity: 0 !important;
      pointer-events: none !important;
      z-index: 1 !important;
    }

    .tumblr-hidden{
      position:fixed;
      top:0; left:0;
      opacity:0;
      pointer-events:none;
      width:1px; height:1px;
      overflow:hidden;
      z-index:-1;
    }

    /* ========================= INTRO ========================= */
    .intro{
      position:fixed;
      inset:0;
      z-index:9999;
      display:flex;
      align-items:center;
      justify-content:center;
      background-image: var(--intro-bg);
      background-repeat: repeat;   /* mosaic */
      background-size: auto;
      background-position: top left;
    }
    .introShade{
      position:absolute;
      inset:0;
      background: rgba(0,0,0,.22);
      pointer-events:none;
    }
    .introCard{
      position:relative;
      width: min(420px, 72vw);
      aspect-ratio: 1 / 1;
      max-height: min(420px, 72vw);
      border-radius: 16px;
      border:1px solid rgba(255,255,255,.16);
      box-shadow: var(--shadow);
      overflow:hidden;
      cursor:pointer;
      user-select:none;
      background: rgba(0,0,0,.20);
      backdrop-filter: blur(8px);
      outline:none;
      display:flex;
      align-items:center;
      justify-content:center;
      padding: 10px;
      z-index: 2;
    }
    .introCard img{
      width:100%;
      height:100%;
      object-fit:contain;
      display:block;
      border-radius: 12px;
      background: rgba(0,0,0,.10);
    }

    /* CTA follows mouse */
    .cta{
      position:fixed;
      z-index:10000;
      pointer-events:none;
      padding:8px 10px;
      border-radius:999px;
      border:1px solid rgba(255,255,255,.18);
      background: rgba(0,0,0,.50);
      color: rgba(255,255,255,.90);
      font-size:12px;
      transform: translate(14px, 14px);
      backdrop-filter: blur(8px);
      opacity:0;
      transition: opacity .12s linear;
      white-space:nowrap;
    }
    .cta.on{ opacity:1; }

    /* Trail layer (above intro) */
    .trailLayer{
      position:fixed;
      inset:0;
      z-index: 10001;
      pointer-events:none;
    }
    .trailItem{
      position:absolute;
      width:auto;
      height:auto;
      transform: translate(-50%, -50%) rotate(var(--r, 0deg));
      opacity: 1;
      filter: drop-shadow(0 10px 18px rgba(0,0,0,.45));
      will-change: transform;
      max-width: 240px;
      max-height: 240px;
    }

    .introFadeOut{ animation:introOut .28s linear forwards; }
    @keyframes introOut{ to{ opacity:0; } }

    /* ========================= OS (NO TOPBAR) ========================= */
    .os{
      position:fixed;
      inset:0;
      opacity:0;
      pointer-events:none;
      background-image: var(--os-wallpaper);
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    }
    .osReady{
      opacity:1;
      pointer-events:auto;
      transition: opacity .18s linear;
    }

    .desktop{
      position:absolute;
      left:0; right:0;
      top:0; bottom:42px; /* NO TOPBAR */
      overflow:hidden;
    }

    /* subtle grid optional */
    .grid{
      position:absolute;
      inset:0;
      background-image:
        linear-gradient(to right, rgba(255,255,255,.10) 1px, transparent 1px),
        linear-gradient(to bottom, rgba(255,255,255,.10) 1px, transparent 1px);
      background-size: 34px 34px;
      opacity:.08;
      pointer-events:none;
    }

    /* ========================= DESKTOP ICONS (Win95-ish) ========================= */
    .iconsLayer{
      position:absolute;
      inset:0;
      z-index:2;
    }
    .deskIcon{
      position:absolute;
      width: 78px;
      padding: 6px 6px 8px;
      display:flex;
      flex-direction:column;
      align-items:center;
      gap:6px;
      user-select:none;
      cursor: default;
      color:#fff;
      font-family: Tahoma, Verdana, Arial, sans-serif;
      text-shadow: 0 1px 2px rgba(0,0,0,.6);
    }
    .deskIcon:active{ cursor: grabbing; }
    .deskIcon .icoBox{
      width: 34px;
      height: 34px;
      display:grid;
      place-items:center;
      background: rgba(255,255,255,.18);
      border: 1px solid rgba(255,255,255,.22);
      border-radius: 4px;
      backdrop-filter: blur(4px);
    }
    .deskIcon .lbl{
      width: 100%;
      text-align:center;
      font-size: 12px;
      line-height: 1.05;
      white-space: normal;
      word-break: break-word;
    }
    .deskIcon.isSelected{
      outline: 1px dotted rgba(255,255,255,.85);
      outline-offset: 2px;
      background: rgba(0,0,0,.15);
      border-radius: 6px;
    }

    /* Trash icon extra hint */
    .deskIcon.isTrash .icoBox{
      background: rgba(255,255,255,.22);
      border-color: rgba(255,255,255,.30);
    }
    .trashHover{
      filter: drop-shadow(0 0 14px rgba(255,255,255,.35));
    }

    /* ========================= TASKBAR (Win95) ========================= */
    .taskbar{
      position:absolute;
      left:0; right:0; bottom:0;
      height: 42px;
      display:flex;
      align-items:center;
      gap:8px;
      padding: 0 8px;
      background: var(--w95-face);
      border-top: 2px solid var(--w95-light);
      font-family: Tahoma, Verdana, Arial, sans-serif;
      z-index: 50;
    }
    .start{
      display:flex;
      align-items:center;
      gap:8px;
      padding:6px 10px;
      border-radius:0;
      border: 2px solid;
      border-color: var(--w95-light) var(--w95-dark) var(--w95-dark) var(--w95-light);
      background: var(--w95-face);
      cursor:pointer;
      user-select:none;
      font-size:12px;
      color: #000;
      white-space:nowrap;
    }
    .start:active{
      border-color: var(--w95-dark) var(--w95-light) var(--w95-light) var(--w95-dark);
      transform: translateY(1px);
    }
    .start .pill{
      width:10px;height:10px;border-radius:0;
      background: #008080;
      border:1px solid var(--w95-dark);
    }
    .tasks{
      display:flex;
      align-items:center;
      gap:6px;
      overflow:auto;
      max-width: 62vw;
      padding: 0 4px;
    }
    .task{
      display:flex;
      align-items:center;
      gap:8px;
      padding:6px 10px;
      border-radius:0;
      border: 2px solid;
      border-color: var(--w95-light) var(--w95-dark) var(--w95-dark) var(--w95-light);
      background: var(--w95-face);
      font-size:12px;
      color: #000;
      white-space:nowrap;
      cursor:pointer;
      user-select:none;
      max-width: 260px;
      overflow:hidden;
      text-overflow:ellipsis;
    }
    .task.isActive{
      border-color: var(--w95-dark) var(--w95-light) var(--w95-light) var(--w95-dark);
      background: var(--w95-hilight);
    }
    .spacer{ flex:1; }
    .clock{
      font-size:12px;
      color: #000;
      padding: 0 8px;
      border: 2px solid;
      border-color: var(--w95-dark) var(--w95-light) var(--w95-light) var(--w95-dark);
      background: var(--w95-hilight);
      height: 28px;
      display:flex;
      align-items:center;
      white-space:nowrap;
    }

    /* ========================= START MENU ========================= */
    .startMenu{
      position:absolute;
      left: 8px;
      bottom: 44px;
      width: 240px;
      background: var(--w95-face);
      border: 2px solid;
      border-color: var(--w95-light) var(--w95-dark) var(--w95-dark) var(--w95-light);
      box-shadow: 0 10px 22px rgba(0,0,0,.35);
      z-index: 60;
      display:none;
      font-family: Tahoma, Verdana, Arial, sans-serif;
      color:#000;
    }
    .startMenu.on{ display:block; }
    .startMenuHeader{
      height: 42px;
      background: linear-gradient(180deg, var(--w95-title), var(--w95-title2));
      color:#fff;
      display:flex;
      align-items:center;
      padding: 0 10px;
      font-weight:700;
      font-size: 13px;
    }
    .startMenuList{ padding: 6px; }
    .menuItem{
      display:flex;
      align-items:center;
      gap:10px;
      padding: 8px 8px;
      cursor:pointer;
      user-select:none;
      border: 1px solid transparent;
    }
    .menuItem:hover{
      background: #000080;
      color:#fff;
    }
    .menuIco{
      width: 22px; height: 22px;
      display:grid; place-items:center;
      background: rgba(0,0,0,.08);
      border: 1px solid rgba(0,0,0,.20);
    }
    .menuSep{
      height:1px;
      background: rgba(0,0,0,.25);
      margin: 6px 0;
    }
    .menuHint{
      font-size: 11px;
      opacity: .75;
      padding: 6px 8px 10px;
    }

    /* ========================= WINDOWS (Win95) ========================= */
    .win{
      position:absolute;
      width: min(860px, calc(100vw - 40px));
      height: min(560px, calc(100vh - 150px));
      left: 180px;
      top: 70px;
      border-radius: 0;
      border: 2px solid;
      border-color: var(--w95-light) var(--w95-dark) var(--w95-dark) var(--w95-light);
      background: var(--w95-face);
      box-shadow: none;
      overflow:hidden;
      z-index:5;
      color: #000;
      font-family: Tahoma, Verdana, Arial, sans-serif;
    }
    .winHeader{
      height: 28px;
      display:flex;
      align-items:center;
      justify-content:space-between;
      padding: 0 6px;
      border-bottom: 2px solid var(--w95-mid);
      background: linear-gradient(90deg, var(--w95-title), var(--w95-title2));
      cursor: grab;
      user-select:none;
      color: #fff;
    }
    .winHeader:active{ cursor: grabbing; }
    .winTitle{
      display:flex;
      align-items:center;
      gap:8px;
      font-weight:700;
      font-size:12px;
      min-width:0;
    }
    .winTitle span:last-child{
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
      max-width: 52vw;
    }
    .winBtns{ display:flex; gap:4px; align-items:center; }
    .btn{
      width: 20px;
      height: 20px;
      display:grid;
      place-items:center;
      border-radius: 0;
      border: 2px solid;
      border-color: var(--w95-light) var(--w95-dark) var(--w95-dark) var(--w95-light);
      background: var(--w95-face);
      color: #000;
      cursor:pointer;
      user-select:none;
      font-size:12px;
      line-height:1;
    }
    .btn:hover{ background: var(--w95-hilight); }
    .btn:active{
      border-color: var(--w95-dark) var(--w95-light) var(--w95-light) var(--w95-dark);
      transform: translateY(1px);
    }
    .winBody{
      height: calc(100% - 28px);
      background: var(--w95-face);
      overflow:auto;
      padding: 12px;
      color:#000;
    }
    .panel{
      border: 2px solid;
      border-color: var(--w95-dark) var(--w95-light) var(--w95-light) var(--w95-dark);
      border-radius:0;
      background: var(--w95-hilight);
      padding: 10px;
      color:#000;
    }
    .muted{ color: rgba(0,0,0,.70); }
    .win.max{
      left: 8px !important;
      top: 8px !important;
      width: calc(100vw - 16px) !important;
      height: calc(100vh - 8px - 50px) !important; /* leave taskbar */
      border-radius: 0;
    }

    /* ========================= Calculator ========================= */
    .calc{
      width: min(340px, 92vw);
      margin: 0 auto;
      background: var(--w95-face);
      border: 2px solid;
      border-color: var(--w95-light) var(--w95-dark) var(--w95-dark) var(--w95-light);
      padding: 10px;
    }
    .calcDisplay{
      width:100%;
      height: 42px;
      background: #fff;
      border: 2px solid;
      border-color: var(--w95-dark) var(--w95-light) var(--w95-light) var(--w95-dark);
      padding: 8px 10px;
      font-family: "Courier New", monospace;
      font-size: 18px;
      display:flex;
      align-items:center;
      justify-content:flex-end;
      overflow:hidden;
    }
    .calcGrid{
      display:grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 8px;
      margin-top: 10px;
    }
    .calcBtn{
      height: 36px;
      display:grid;
      place-items:center;
      border: 2px solid;
      border-color: var(--w95-light) var(--w95-dark) var(--w95-dark) var(--w95-light);
      background: var(--w95-face);
      cursor:pointer;
      user-select:none;
      font-size: 14px;
    }
    .calcBtn:active{
      border-color: var(--w95-dark) var(--w95-light) var(--w95-light) var(--w95-dark);
      transform: translateY(1px);
    }
    .calcNote{
      margin-top: 8px;
      font-size: 11px;
      opacity: .75;
    }

    @media (max-width: 560px){
      .win{
        left: 10px !important;
        top: 64px !important;
        width: calc(100vw - 20px) !important;
        height: calc(100vh - 64px - 52px) !important;
      }
      .tasks{ max-width: 52vw; }
    }

    @media (prefers-reduced-motion: reduce){
      .introFadeOut{ animation:none; }
      .osReady{ transition:none; }
      .cta{ transition:none; }
    }
  </style>
</head>

<body>
  <div class="tumblr-hidden">
    {block:Pagination}{/block:Pagination}
    {block:Posts}{/block:Posts}
  </div>

  <!-- INTRO -->
  <div id="intro" class="intro" aria-label="Intro">
    <div class="introShade"></div>
    <div id="trailLayer" class="trailLayer" aria-hidden="true"></div>
    <div id="introCard" class="introCard" tabindex="0" role="button" aria-label="Continue">
      <img id="introImg" alt="Continue window" />
    </div>
  </div>

  <div id="cta" class="cta">CLICK TO CONTINUE</div>

  <!-- OS -->
  <div id="os" class="os" aria-label="OS">
    <div class="desktop" id="desktop">
      <div class="grid"></div>
      <div class="iconsLayer" id="iconsLayer"></div>
    </div>

    <div class="taskbar">
      <div class="start" id="startBtn">
        <span class="pill"></span>
        <span>Start</span>
      </div>
      <div class="tasks" id="tasks"></div>
      <div class="spacer"></div>
      <div class="clock" id="clock2">--:--</div>
    </div>

    <div class="startMenu" id="startMenu" aria-label="Start menu">
      <div class="startMenuHeader">KeanuOS</div>
      <div class="startMenuList">
        <div class="menuItem" data-open="calculator">
          <div class="menuIco">🧮</div>
          <div>Calculator</div>
        </div>
        <div class="menuItem" data-open="about">
          <div class="menuIco">📝</div>
          <div>About</div>
        </div>
        <div class="menuSep"></div>
        <div class="menuItem" data-open="future">
          <div class="menuIco">⚙️</div>
          <div>Settings (future)</div>
        </div>
        <div class="menuItem" data-open="future2">
          <div class="menuIco">📁</div>
          <div>Programs (future)</div>
        </div>
      </div>
      <div class="menuHint">More items can be added later.</div>
    </div>
  </div>

  <script>
    /* =========================================================
      INTRO ASSETS (RAW) — ensure image loads reliably
    ========================================================= */
    const bgUrl = "https://raw.githubusercontent.com/KeanuCheese/Theme-K/05b4cb69a1d7915199918635767714e3fcd53605/Fondo_intro";
    const winUrl = "https://raw.githubusercontent.com/KeanuCheese/Theme-K/05b4cb69a1d7915199918635767714e3fcd53605/Imagen%20intro";

    const p1 = new Image(); p1.src = bgUrl;
    const p2 = new Image(); p2.src = winUrl;

    const introImgEl = document.getElementById("introImg");
    introImgEl.referrerPolicy = "no-referrer";
    introImgEl.decoding = "async";
    introImgEl.loading = "eager";
    introImgEl.src = winUrl;

    const intro = document.getElementById("intro");
    const introCard = document.getElementById("introCard");
    const cta = document.getElementById("cta");
    const os = document.getElementById("os");
    const desktop = document.getElementById("desktop");
    const tasksEl = document.getElementById("tasks");
    const iconsLayer = document.getElementById("iconsLayer");
    const trailLayer = document.getElementById("trailLayer");
    const startBtn = document.getElementById("startBtn");
    const startMenu = document.getElementById("startMenu");

    /* =========================================================
      MOUSE TRAIL (intro only)
    ========================================================= */
    const TRAIL_GIFS = [
