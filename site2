let selected=null,z=30; const wins=new Map();
const iconsEl=document.getElementById('icons'),tasks=document.getElementById('tasks'),startBtn=document.getElementById('startBtn'),startMenu=document.getElementById('startMenu');
function mkWindow(id,title,icon,html){
  if(wins.has(id)){const w=wins.get(id);w.el.style.display='flex';focus(w);return w.el}
  const el=document.createElement('div');el.className='win';el.dataset.id=id;el.style.left=(90+Math.random()*140)+'px';el.style.top=(60+Math.random()*90)+'px';
  el.innerHTML=`<div class='head'><div class='title'><span>${icon}</span><span>${title}</span></div><div class='btns'><div class='btn' data-a='min'>—</div><div class='btn' data-a='max'>▢</div><div class='btn' data-a='close'>✕</div></div></div><div class='body'>${html}</div>`;
  document.getElementById('desktop').appendChild(el);
  const task=document.createElement('div');task.className='task active';task.textContent=title;tasks.appendChild(task);
  const state={el,task};wins.set(id,state);focus(state);sound('open');
  task.onclick=()=>{if(el.style.display==='none'){el.style.display='flex';focus(state)}else if(task.classList.contains('active')){el.style.display='none';task.classList.remove('active')}else focus(state);updateMinimizedMenu()};
  el.addEventListener('mousedown',()=>focus(state));
  const head=el.querySelector('.head');let drag=false,sx=0,sy=0,ox=0,oy=0;
  head.onmousedown=e=>{if(el.classList.contains('max'))return;drag=true;sx=e.clientX;sy=e.clientY;const r=el.getBoundingClientRect();ox=r.left;oy=r.top};
  addEventListener('mousemove',e=>{if(!drag)return;el.style.left=Math.max(4,Math.min(innerWidth-el.offsetWidth-4,ox+e.clientX-sx))+'px';el.style.top=Math.max(4,Math.min(innerHeight-el.offsetHeight-46,oy+e.clientY-sy))+'px'},{passive:true});
  addEventListener('mouseup',()=>drag=false);
  head.onclick=e=>{const b=e.target.closest('.btn');if(!b)return;const a=b.dataset.a;if(a==='min'){el.style.display='none';task.classList.remove('active');sound('min')}if(a==='max'){el.classList.toggle('max');b.textContent=el.classList.contains('max')?'❐':'▢'}if(a==='close'){el.remove();task.remove();wins.delete(id);sound('close')}updateMinimizedMenu()};
  head.ondblclick=()=>{const b=head.querySelector('[data-a=max]');b.click();};
  return el;
}

function updateMinimizedMenu(){
  const minList=document.getElementById('minList');
  if(!minList) return;
  const hidden=[...wins.entries()].filter(([,st])=>st.el.style.display==='none');
  if(!hidden.length){minList.innerHTML="<div class='tiny' style='padding:6px 8px'>Sin ventanas minimizadas</div>";return;}
  minList.innerHTML=hidden.map(([id,s])=>`<div class='menuItem' data-restore='${id}'><span>🗔</span><span>${s.task.textContent}</span></div>`).join('');
}

function focus(state){z++;state.el.style.zIndex=z;document.querySelectorAll('.task').forEach(t=>t.classList.remove('active'));state.task.classList.add('active')}
function openApp(id){const m=modules[id];if(!m)return sound('error');const w=mkWindow(id,m.title,m.icon,m.html);if(id==='run'){const i=w.querySelector('#runInput');const g=w.querySelector('#runGo');g.onclick=()=>{const v=i.value.trim();if(!v)return; if(v.startsWith('app://'))openApp(v.replace('app://','')); else openURLWindow(v,'🌐',v);};}}
function urlToEmbed(url){
  try{const u=new URL(url);
    if(u.hostname.includes('youtube.com')||u.hostname.includes('youtube-nocookie.com')||u.hostname.includes('youtu.be')){
      let vid='';
      if(u.hostname.includes('youtu.be')) vid=u.pathname.slice(1);
      else if(u.hostname.includes('youtube-nocookie.com') && u.pathname.includes('/embed/')) vid=u.pathname.split('/embed/')[1].split('/')[0];
      else if(u.pathname.includes('/embed/')) vid=u.pathname.split('/embed/')[1].split('/')[0];
      else vid=u.searchParams.get('v');
      if(vid) return `https://www.youtube-nocookie.com/embed/${vid}?autoplay=0&rel=0&modestbranding=1&playsinline=1`;
    }
    if(u.hostname.includes('odysee.com')) return `https://odysee.com/$/embed${u.pathname}${u.search}`;
    if(url.toLowerCase().endsWith('.pdf')) return `https://drive.google.com/viewerng/viewer?embedded=1&url=${encodeURIComponent(url)}`;
    if(u.hostname.includes('drive.google.com') && u.pathname.includes('/file/d/')){const parts=u.pathname.split('/file/d/')[1];const id=parts.split('/')[0];if(id) return `https://drive.google.com/file/d/${id}/preview`;}
  }catch{}
  return url;
}
function openURLWindow(title,icon,url){const embed=urlToEmbed(url);const media=(url.includes('youtube')||url.includes('youtu.be')||url.includes('youtube-nocookie')||url.toLowerCase().includes('.pdf')||url.includes('drive.google.com'));if(media){const vertical=/teaser|shorts|vertical/i.test(title+url);openModal(embed,vertical,url);return;}mkWindow('url:'+title,title,icon,`<div class='panel' style='display:flex;flex-direction:column;gap:0'><iframe class='embed' src='${embed}' allow='autoplay; fullscreen; encrypted-media; picture-in-picture' referrerpolicy='strict-origin-when-cross-origin' loading='lazy'></iframe><div class='sourceLink'><a href='${url}' target='_blank' rel='noopener'>${url}</a></div></div>`)}
function openFolder(id){const f=modules[id];if(!f)return;const html=`<div class='panel'><div class='folderGrid'>${f.items.map((it,ix)=>`<div class='entry' data-i='${ix}'><div>${it.icon}</div><div><b>${it.name}</b><div class='tiny'>Abrir en ventana del sistema</div></div></div>`).join('')}</div></div>`;const w=mkWindow(id,f.title,f.icon,html);w.querySelectorAll('.entry').forEach(e=>e.onclick=()=>{const it=f.items[+e.dataset.i];openURLWindow(it.name,it.icon,it.url)});
}

function renderIcons(){iconsEl.innerHTML='';desktopIcons.forEach(ic=>{const el=document.createElement('div');el.className='deskIcon';el.style.left=ic.x+'px';el.style.top=ic.y+'px';el.innerHTML=`<div class='box'>${ic.icon}</div><div class='lbl'>${ic.label}</div>`;let drag=false,dx=0,dy=0,moved=false;el.addEventListener('click',e=>{e.stopPropagation();document.querySelectorAll('.deskIcon').forEach(d=>d.classList.remove('sel'));el.classList.add('sel');selected=el;});el.addEventListener('dblclick',e=>{e.stopPropagation();ic.open();});el.addEventListener('pointerdown',e=>{if(e.button!==0)return;drag=true;moved=false;const r=el.getBoundingClientRect();dx=e.clientX-r.left;dy=e.clientY-r.top;el.setPointerCapture(e.pointerId)});el.addEventListener('pointermove',e=>{if(!drag)return;moved=true;const nx=Math.max(4,Math.min(innerWidth-el.offsetWidth-4,e.clientX-dx));const ny=Math.max(4,Math.min(innerHeight-el.offsetHeight-52,e.clientY-dy));el.style.left=nx+'px';el.style.top=ny+'px'});el.addEventListener('pointerup',()=>{drag=false;ic.x=parseInt(el.style.left)||ic.x;ic.y=parseInt(el.style.top)||ic.y;});iconsEl.appendChild(el);});}
renderIcons();
addEventListener('click',()=>{document.querySelectorAll('.deskIcon').forEach(d=>d.classList.remove('sel'));startMenu.classList.remove('on')});
