let bag=[],last="",spawnAt=0;
function refill(){bag=[...TRAIL_GIFS].sort(()=>Math.random()-.5)}
function pick(){if(!bag.length)refill();let v=bag.pop();if(v===last&&bag.length)v=bag.pop();last=v;return v}
