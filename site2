<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>{Title}</title>
  <style>
    :root{
      --intro-bg:url("Fondo_intro");
      --intro-win:url("Imagen%20intro");
      --os-wall:url("brokensc-1536x864.jpg");
      --face:#c0c0c0; --light:#fff; --dark:#000; --mid:#808080; --hilight:#dfdfdf;
      --title:#000080; --title2:#1084d0;
    }
    *{box-sizing:border-box}
    html,body{height:100%}
    body{margin:0;overflow:hidden;font-family:Tahoma,Verdana,Arial,sans-serif;background:#111}
    iframe.tmblr-iframe,.tmblr-iframe{display:none!important;opacity:0!important;pointer-events:none!important}
    a[href*="instagram.com/triunvirato.elemental"],
    [href*="instagram.com/triunvirato.elemental"]{display:none!important}

    .intro{position:fixed;inset:0;display:flex;align-items:center;justify-content:center;z-index:1000;background:rgba(0,0,0,.2) var(--intro-bg) repeat}
    .introCard{width:min(420px,74vw);aspect-ratio:1;border:1px solid rgba(255,255,255,.25);border-radius:12px;padding:8px;background:rgba(0,0,0,.25);cursor:pointer;position:relative}
    .introCard img{width:100%;height:100%;object-fit:contain;border-radius:8px}
    .cta{position:fixed;z-index:1001;padding:7px 10px;background:rgba(0,0,0,.55);color:#fff;font-size:12px;border-radius:999px;pointer-events:none;opacity:0;transform:translate(14px,14px)}
    .cta.on{opacity:1}
    .trailLayer{position:fixed;inset:0;z-index:1002;pointer-events:none}
    .trailItem{position:absolute;max-width:220px;max-height:220px;transform:translate(-50%,-50%) rotate(var(--r));filter:drop-shadow(0 8px 12px rgba(0,0,0,.4))}

    .os{position:fixed;inset:0;background:var(--os-wall) center/cover no-repeat;opacity:0;pointer-events:none}
    .os.on{opacity:1;pointer-events:auto;transition:opacity .2s linear}
    .desktop{position:absolute;inset:0 0 58px;overflow:hidden}
    .icons{position:absolute;inset:0}
    .deskIcon{position:absolute;width:88px;padding:5px;display:flex;flex-direction:column;gap:6px;align-items:center;color:#fff;text-shadow:0 1px 2px #000;cursor:default;user-select:none}
    .deskIcon .box{width:36px;height:36px;border:1px solid rgba(255,255,255,.3);background:rgba(255,255,255,.18);display:grid;place-items:center;border-radius:4px}
    .deskIcon .lbl{font-size:12px;text-align:center;line-height:1.1;word-break:break-word}
    .deskIcon.sel{outline:1px dotted #fff;outline-offset:2px;background:rgba(0,0,0,.2)}

    .taskbar{position:absolute;left:0;right:0;bottom:0;height:42px;padding:0 8px;background:var(--face);border-top:1px solid #7a7a7a;display:flex;align-items:center;gap:8px;z-index:200}
    .start,.task,.clock,.startMenu,.btn,.calcBtn{border:1px solid #2f2f2f;background:var(--face)}
    .start{padding:6px 10px;display:flex;gap:8px;align-items:center;cursor:pointer;font-size:12px}
    .start:active,.task.active,.btn:active,.calcBtn:active{border-color:var(--dark) var(--light) var(--light) var(--dark)}
    .tasks{display:flex;gap:6px;overflow:auto;max-width:70vw}
    .task{padding:6px 10px;font-size:12px;max-width:220px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;cursor:pointer}
    .spacer{flex:1}
    .clock{height:28px;padding:0 9px;display:flex;align-items:center;font-size:12px}
    .audioCtrl{width:28px;height:28px;display:grid;place-items:center;border:1px solid #2f2f2f;background:#d7d7d7;cursor:pointer;font-size:12px;user-select:none}
    .audioCtrl:hover{background:#efefef}

    .modal{position:fixed;inset:0;display:none;align-items:center;justify-content:center;background:rgba(0,0,0,.72);z-index:1200}
    .modal.active{display:flex}
    .modalContent{position:relative;width:min(1100px,92vw);height:min(82vh,760px);background:#111;border:1px solid #666;padding:26px 8px 8px}
    .modalContent.vertical{width:min(520px,92vw);height:min(90vh,860px)}
    .modalClose{position:absolute;top:4px;right:6px;width:22px;height:20px;display:grid;place-items:center;background:#d7d7d7;border:1px solid #2d2d2d;color:#000;cursor:pointer}
    .modalFrame{width:100%;height:100%;border:none;background:#000}

    .startMenu{position:absolute;left:8px;bottom:44px;width:260px;display:none;z-index:220}
    .startMenu.on{display:block}
    .smHead{height:40px;padding:0 10px;background:linear-gradient(180deg,var(--title),var(--title2));color:#fff;display:flex;align-items:center;font-weight:700}
    .smBody{padding:6px}
    .menuItem{position:relative;padding:8px;display:flex;align-items:center;gap:10px;border:1px solid transparent;font-size:13px;cursor:pointer}
    .menuItem:hover{background:#000080;color:#fff}
    .menuSep{height:1px;background:rgba(0,0,0,.3);margin:5px 0}
    .arrow{margin-left:auto}

    .win{position:absolute;left:110px;top:70px;width:min(920px,calc(100vw - 24px));height:min(640px,calc(100vh - 88px));background:var(--face);border:1px solid #1f1f1f;box-shadow:0 10px 18px rgba(0,0,0,.35);z-index:20;display:flex;flex-direction:column}
    .win.max{left:6px!important;top:6px!important;width:calc(100vw - 12px)!important;height:calc(100vh - 52px)!important}
    .head{height:28px;background:linear-gradient(90deg,var(--title),var(--title2));display:flex;align-items:center;justify-content:space-between;color:#fff;padding:0 6px;cursor:grab}
    .title{display:flex;gap:8px;font-size:12px;font-weight:700;align-items:center;min-width:0}
    .title span:last-child{white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .btns{display:flex;gap:4px;align-items:center}
    .btn{width:20px;height:18px;display:grid;place-items:center;cursor:pointer;font-size:11px;font-weight:700;color:#000;background:#d8d8d8;border:1px solid #2d2d2d;border-radius:3px;line-height:1;padding:0}
    .body{flex:1;background:#d4d4d4;padding:0;overflow:auto}
    .panel{background:#efefef;padding:10px;border:none;font-size:13px;height:100%}
    .embed{width:100%;height:100%;min-height:420px;border:none;background:#000}
    .tiny{font-size:11px;color:#333}.sourceLink{margin-top:6px;text-align:right;font-size:11px;color:#1f3f7f;word-break:break-all}.sourceLink a{color:inherit;text-decoration:none}.sourceLink a:hover{text-decoration:underline}
    .folderGrid{display:flex;flex-direction:column;gap:4px}
    .entry{display:flex;gap:8px;align-items:center;padding:6px 8px;border:1px solid #b3b3b3;background:#f5f5f5;cursor:pointer;width:100%}
    .entry:hover{background:#dce8ff}
    .entry b{font-weight:600}

    .introCredit{position:absolute;bottom:-30px;left:50%;transform:translateX(-50%);color:#fff;font-size:12px;text-shadow:0 1px 2px #000;white-space:nowrap}

    .footer{display:none}
    @media (max-width:680px){.win{left:8px!important;top:54px!important;width:calc(100vw - 16px)!important;height:calc(100vh - 102px)!important}.tasks{max-width:54vw}}
  </style>
</head>
