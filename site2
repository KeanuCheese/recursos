startBtn.onclick=e=>{e.stopPropagation();updateMinimizedMenu();startMenu.classList.toggle('on')};
startMenu.onclick=e=>{const item=e.target.closest('.menuItem');if(!item)return;const restore=item.dataset.restore;if(restore&&wins.get(restore)){const st=wins.get(restore);st.el.style.display='flex';focus(st);startMenu.classList.remove('on');updateMinimizedMenu();return;}startMenu.classList.remove('on');const act=item.dataset.open;
  if(act==='shutdown'){os.classList.remove('on');intro.style.display='flex';cta.style.display='block';sound('close');return;}
  if(act==='discord'){window.open('https://discord.com/users/849764011670110250','_blank','noopener');return;}
  if(act==='tumblr')return openURLWindow('Tumblr','🌀','https://dadaisnothingmeh.tumblr.com/');
  if(act==='skatehive')return openURLWindow('Skatehive','🛹','https://skatehive.app/user/keanucheese?view=snaps');
  if(['programs','documents','run'].includes(act))return openApp(act);
};


const modal=document.getElementById('modal'),modalFrame=document.getElementById('modalFrame'),modalContent=document.getElementById('modalContent');
function openModal(url,vertical=false,source=''){modalFrame.src=url;modal.classList.add('active');modalContent.classList.toggle('vertical',!!vertical);modal.setAttribute('aria-hidden','false');}
function closeModal(){modal.classList.remove('active');modal.setAttribute('aria-hidden','true');modalFrame.src='';}
document.getElementById('modalClose').onclick=closeModal;
modal.addEventListener('click',e=>{if(e.target===modal)closeModal()});
addEventListener('keydown',e=>{if(e.key==='Escape'&&modal.classList.contains('active'))closeModal()});

let ambientPlayer=null,ambientReady=false,ambientPlaying=false,apiLoading=false;
function setAudioButtonsIcon(txt){const b1=document.getElementById('audioBtnIntro');const b2=document.getElementById('audioBtnTask');if(b1)b1.textContent=txt;if(b2)b2.textContent=txt;}
function initAmbientPlayer(){
  if(ambientPlayer||apiLoading) return;
  apiLoading=true;
  const tag=document.createElement('script');tag.src='https://www.youtube.com/iframe_api';document.body.appendChild(tag);
}
window.onYouTubeIframeAPIReady=function(){
  ambientPlayer=new YT.Player('yt-player',{videoId:'4YbEnmqDlWw',playerVars:{autoplay:1,controls:0,loop:1,playlist:'4YbEnmqDlWw',mute:1,modestbranding:1,playsinline:1,rel:0},events:{onReady:(e)=>{ambientReady=true;ambientPlaying=true;setAudioButtonsIcon('⏸');e.target.playVideo();e.target.setVolume(40);},onStateChange:(e)=>{ambientPlaying=e.data===1;setAudioButtonsIcon(ambientPlaying?'⏸':'▶');}}});
};
function attemptUnmute(){if(!ambientPlayer||!ambientReady) return;try{ambientPlayer.unMute();ambientPlayer.setVolume(40);}catch{}}
function toggleAmbient(){if(!ambientPlayer){initAmbientPlayer();return;}const st=ambientPlayer.getPlayerState?.();if(st===1){ambientPlayer.pauseVideo();setAudioButtonsIcon('▶');}else{ambientPlayer.playVideo();attemptUnmute();setAudioButtonsIcon('⏸');}}
document.getElementById('audioBtnIntro').addEventListener('click',e=>{e.stopPropagation();toggleAmbient()});
document.getElementById('audioBtnTask').addEventListener('click',e=>{e.stopPropagation();toggleAmbient()});

