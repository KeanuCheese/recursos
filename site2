function loadFirstImage(urls, apply){const list=[...new Set(urls.filter(Boolean))];const tryAt=(i)=>{if(i>=list.length)return;const img=new Image();img.onload=()=>apply(list[i]);img.onerror=()=>tryAt(i+1);img.src=list[i];};tryAt(0);}
