function normalizeEmbed(url){
  if(url.includes('youtube.com/watch')){const u=new URL(url);const v=u.searchParams.get('v');return `https://www.youtube-nocookie.com/embed/${v}?autoplay=1`;}
  if(url.includes('youtu.be/')){const v=url.split('youtu.be/')[1].split('?')[0];return `https://www.youtube-nocookie.com/embed/${v}?autoplay=1`;}
  if(url.includes('odysee.com/')){return url.replace('odysee.com/','odysee.com/$/embed/');}
  return url;
}

