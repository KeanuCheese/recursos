startMenu.addEventListener('click',e=>{
  const it=e.target.closest('.menuItem'); if(!it||it.classList.contains('hasSub')) return;
  if(it.dataset.action==='shutdown'){toggleStart(false); os.classList.remove('osReady'); intro.style.display='flex'; cta.style.display='block'; return;}
  if(it.dataset.external==='1'){window.open(it.dataset.link,'_blank','noopener'); toggleStart(false); return;}
  if(it.dataset.link){
    const id='link_'+btoa(it.dataset.link).replace(/=/g,''); ITEMS[id]={title:it.textContent.trim(),icon:'🌐',type:'web',url:it.dataset.link}; openApp(id); toggleStart(false); return;
  }
  if(it.dataset.open){ openApp(it.dataset.open); toggleStart(false); }
});

