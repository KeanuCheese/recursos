const openWindows=new Map(); let zTop=10;
function mkBody(item){
  if(item.type==='text') return item.html;
  if(item.type==='calc') return `<div class="calc" id="calcRoot"><div class="calcDisplay" id="calcDisplay">0</div><div class="calcGrid">${['C','⌫','%','/','7','8','9','*','4','5','6','-','1','2','3','+','0','.','=','*'].slice(0,19).map(k=>`<div class="calcBtn" data-k="${k==='*'?'=':k}">${k==='*'?'×':k}</div>`).join('')}</div></div>`;
  if(item.type==='list') return `<div class="panel"><div class="docList">${item.items.map((it,i)=>`<div class="docItem" data-idx="${i}"><div>${it.icon}</div><div><div>${it.title}</div><div class="muted">${it.url}</div></div></div>`).join('')}</div></div>`;
  const src=normalizeEmbed(item.url);
  return `<iframe class="viewerFrame" referrerpolicy="no-referrer" allowfullscreen src="${src}"></iframe>`;
}
function focusWindow(win,task){zTop++; win.style.zIndex=zTop; document.querySelectorAll('.task').forEach(t=>t.classList.remove('isActive')); task.classList.add('isActive');}
function attachDrag(win,header){let on=false,sx=0,sy=0,sl=0,st=0; header.addEventListener('pointerdown',e=>{if(e.target.closest('.btn'))return;on=true;sx=e.clientX;sy=e.clientY;sl=win.offsetLeft;st=win.offsetTop;});window.addEventListener('pointermove',e=>{if(!on||win.classList.contains('max'))return;win.style.left=Math.max(8,Math.min(innerWidth-win.offsetWidth-8,sl+e.clientX-sx))+'px';win.style.top=Math.max(8,Math.min(innerHeight-win.offsetHeight-50,st+e.clientY-sy))+'px';});window.addEventListener('pointerup',()=>on=false);}
function buildWindow(id){
  const mod=ITEMS[id]; if(!mod) return;
  const win=document.createElement('div'); win.className='win'; win.dataset.id=id;
  win.style.left=(80+Math.random()*120)+'px'; win.style.top=(52+Math.random()*80)+'px';
  win.innerHTML=`<div class="winHeader"><div class="winTitle"><span>${mod.icon}</span><span>${mod.title}</span></div><div class="winBtns"><div class="btn" data-act="min">_</div><div class="btn" data-act="max">□</div><div class="btn" data-act="close">×</div></div></div><div class="winBody ${mod.type==='web'?'noPad':''}">${mkBody(mod)}</div>`;
  desktop.appendChild(win);
  const task=document.createElement('div'); task.className='task isActive'; task.textContent=mod.title; tasksEl.appendChild(task);
  openWindows.set(id,{win,task});
  const header=win.querySelector('.winHeader'); attachDrag(win,header);
  header.addEventListener('click',e=>{const b=e.target.closest('.btn'); if(!b) return; const a=b.dataset.act; if(a==='min'){win.style.display='none';task.classList.remove('isActive');beep('min');} if(a==='max'){win.classList.toggle('max');} if(a==='close'){win.remove();task.remove();openWindows.delete(id);beep('close');}});
  header.addEventListener('dblclick',()=>header.querySelector('[data-act=max]').click());
  task.addEventListener('click',()=>{ if(win.style.display==='none'){win.style.display='block';} else if(task.classList.contains('isActive')){win.style.display='none'; task.classList.remove('isActive'); return;} focusWindow(win,task); });
  win.addEventListener('mousedown',()=>focusWindow(win,task));
  if(mod.type==='list'){
    win.querySelectorAll('.docItem').forEach(el=>el.addEventListener('dblclick',()=>{const it=mod.items[+el.dataset.idx]; openViewer(it);}));
  }
  focusWindow(win,task); beep('open');
}
function openViewer(it){
  if(it.kind==='pdf'||it.kind==='video'||it.kind==='web'){
    const id='view_'+it.title.replace(/\W+/g,'_');
    ITEMS[id]={title:it.title,icon:it.icon||'📄',type:'web',url:it.url};
    openApp(id);
  }
}
function openApp(id){if(openWindows.has(id)){const w=openWindows.get(id);w.win.style.display='block';focusWindow(w.win,w.task);return;} buildWindow(id);}

