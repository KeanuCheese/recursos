<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>{Title}</title>
  <style>
    :root{
      --intro-bg:url("https://raw.githubusercontent.com/KeanuCheese/Theme-K/05b4cb69a1d7915199918635767714e3fcd53605/Fondo_intro");
      --intro-win:url("https://raw.githubusercontent.com/KeanuCheese/Theme-K/05b4cb69a1d7915199918635767714e3fcd53605/Imagen%20intro");
      --os-wall:url("https://raw.githubusercontent.com/KeanuCheese/Theme-K/b89546ac5c77afc7d6f8aba43af1cde396caa31c/brokensc-1536x864.jpg");
      --face:#c0c0c0; --light:#fff; --dark:#000; --mid:#808080; --hilight:#dfdfdf;
      --title:#000080; --title2:#1084d0;
    }
    *{box-sizing:border-box}
    html,body{height:100%}
    body{margin:0;overflow:hidden;font-family:Tahoma,Verdana,Arial,sans-serif;background:#111}
    iframe.tmblr-iframe,.tmblr-iframe{opacity:0!important;pointer-events:none!important}

    .intro{position:fixed;inset:0;display:flex;align-items:center;justify-content:center;z-index:1000;background:rgba(0,0,0,.2) var(--intro-bg) repeat}
    .introCard{width:min(420px,74vw);aspect-ratio:1;border:1px solid rgba(255,255,255,.2);border-radius:12px;padding:8px;background:rgba(0,0,0,.25);cursor:pointer}
    .introCard img{width:100%;height:100%;object-fit:contain;border-radius:8px}
    .cta{position:fixed;z-index:1001;padding:7px 10px;background:rgba(0,0,0,.55);color:#fff;font-size:12px;border-radius:999px;pointer-events:none;opacity:0;transform:translate(14px,14px)}
    .cta.on{opacity:1}
    .trailLayer{position:fixed;inset:0;z-index:1002;pointer-events:none}
    .trailItem{position:absolute;max-width:220px;max-height:220px;transform:translate(-50%,-50%) rotate(var(--r));filter:drop-shadow(0 8px 12px rgba(0,0,0,.4))}

    .os{position:fixed;inset:0;background:var(--os-wall) center/cover no-repeat;opacity:0;pointer-events:none}
    .os.on{opacity:1;pointer-events:auto;transition:opacity .2s linear}
    .desktop{position:absolute;inset:0 0 58px;overflow:hidden}
    .icons{position:absolute;inset:0}
    .deskIcon{position:absolute;width:88px;padding:5px;display:flex;flex-direction:column;gap:6px;align-items:center;color:#fff;text-shadow:0 1px 2px #000;cursor:default;user-select:none}
    .deskIcon .box{width:36px;height:36px;border:1px solid rgba(255,255,255,.3);background:rgba(255,255,255,.18);display:grid;place-items:center;border-radius:4px}
    .deskIcon .lbl{font-size:12px;text-align:center;line-height:1.1;word-break:break-word}
    .deskIcon.sel{outline:1px dotted #fff;outline-offset:2px;background:rgba(0,0,0,.2)}

    .taskbar{position:absolute;left:0;right:0;bottom:0;height:42px;padding:0 8px;background:var(--face);border-top:2px solid var(--light);display:flex;align-items:center;gap:8px;z-index:80}
    .start,.task,.clock,.startMenu,.btn,.calcBtn{border:2px solid;border-color:var(--light) var(--dark) var(--dark) var(--light);background:var(--face)}
    .start{padding:6px 10px;display:flex;gap:8px;align-items:center;cursor:pointer;font-size:12px}
    .start:active,.task.active,.btn:active,.calcBtn:active{border-color:var(--dark) var(--light) var(--light) var(--dark)}
    .tasks{display:flex;gap:6px;overflow:auto;max-width:70vw}
    .task{padding:6px 10px;font-size:12px;max-width:220px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;cursor:pointer}
    .spacer{flex:1}
    .clock{height:28px;padding:0 9px;display:flex;align-items:center;font-size:12px}

    .startMenu{position:absolute;left:8px;bottom:44px;width:260px;display:none;z-index:90}
    .startMenu.on{display:block}
    .smHead{height:40px;padding:0 10px;background:linear-gradient(180deg,var(--title),var(--title2));color:#fff;display:flex;align-items:center;font-weight:700}
    .smBody{padding:6px}
    .menuItem{position:relative;padding:8px;display:flex;align-items:center;gap:10px;border:1px solid transparent;font-size:13px;cursor:pointer}
    .menuItem:hover{background:#000080;color:#fff}
    .menuSep{height:1px;background:rgba(0,0,0,.3);margin:5px 0}
    .arrow{margin-left:auto}

    .win{position:absolute;left:110px;top:70px;width:min(920px,calc(100vw - 24px));height:min(640px,calc(100vh - 88px));background:var(--face);border:2px solid;border-color:var(--light) var(--dark) var(--dark) var(--light);z-index:20;display:flex;flex-direction:column}
    .win.max{left:6px!important;top:6px!important;width:calc(100vw - 12px)!important;height:calc(100vh - 52px)!important}
    .head{height:28px;background:linear-gradient(90deg,var(--title),var(--title2));display:flex;align-items:center;justify-content:space-between;color:#fff;padding:0 6px;cursor:grab}
    .title{display:flex;gap:8px;font-size:12px;font-weight:700;align-items:center;min-width:0}
    .title span:last-child{white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .btns{display:flex;gap:4px}
    .btn{width:20px;height:20px;display:grid;place-items:center;cursor:pointer;font-size:12px;color:#000}
    .body{flex:1;background:var(--face);padding:8px;overflow:auto}
    .panel{background:#fff;padding:10px;border:2px solid;border-color:var(--dark) var(--light) var(--light) var(--dark);font-size:13px}
    .embed{width:100%;height:100%;min-height:420px;border:none;background:#000}
    .tiny{font-size:11px;color:#333}
    .folderGrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:8px}
    .entry{display:flex;gap:8px;align-items:flex-start;padding:8px;border:1px solid #b3b3b3;background:#f5f5f5;cursor:pointer}
    .entry:hover{background:#e7eefb}

    .footer{position:absolute;left:8px;right:8px;bottom:44px;display:flex;justify-content:center;pointer-events:none;color:#fff;text-shadow:0 1px 2px #000;font-size:12px;z-index:10}
    @media (max-width:680px){.win{left:8px!important;top:54px!important;width:calc(100vw - 16px)!important;height:calc(100vh - 102px)!important}.tasks{max-width:54vw}}
  </style>
</head>
<body>
<div id="intro" class="intro">
  <div class="trailLayer" id="trail"></div>
  <div id="introCard" class="introCard" tabindex="0"><img src="https://raw.githubusercontent.com/KeanuCheese/Theme-K/05b4cb69a1d7915199918635767714e3fcd53605/Imagen%20intro" alt="Intro"/></div>
</div>
<div id="cta" class="cta">CLICK TO CONTINUE</div>

<div id="os" class="os" aria-label="KeanuOS">
  <div class="desktop" id="desktop"><div class="icons" id="icons"></div></div>
  <div class="footer">Made with love by Keanucheese</div>
  <div class="taskbar">
    <div class="start" id="startBtn"><span>🟩</span><span>Start</span></div>
    <div class="tasks" id="tasks"></div><div class="spacer"></div><div class="clock" id="clock">--:--</div>
  </div>
  <div class="startMenu" id="startMenu">
    <div class="smHead">KeanuOS</div>
    <div class="smBody">
      <div class="menuItem" data-open="programs"><span>📂</span><span>Programs</span><span class="arrow">▶</span></div>
      <div class="menuItem" data-open="documents"><span>📄</span><span>Documents</span></div>
      <div class="menuItem" data-open="run"><span>🏃</span><span>Run…</span></div>
      <div class="menuSep"></div>
      <div class="menuItem" data-open="discord"><span>💬</span><span>Discord</span></div>
      <div class="menuItem" data-open="tumblr"><span>🌀</span><span>Tumblr</span></div>
      <div class="menuItem" data-open="skatehive"><span>🛹</span><span>Skatehive</span></div>
      <div class="menuSep"></div>
      <div class="menuItem" data-open="shutdown"><span>⏻</span><span>Shutdown</span></div>
    </div>
  </div>
</div>

<script>
const TRAIL_GIFS = [
"https://tenor.com/ipY7oKXzzXs.gif","https://tenor.com/mNE9tPvd9HO.gif","https://tenor.com/iA80uU51C8b.gif","https://tenor.com/b2rCy.gif","https://tenor.com/skB9ZQoDGoh.gif","https://tenor.com/BxeRXuk5ch.gif","https://tenor.com/b2fYS.gif","https://tenor.com/brdvX.gif","https://tenor.com/nofHmm2nWtU.gif","https://tenor.com/HfwC.gif","https://tenor.com/Lm0I.gif","https://tenor.com/tpeA2skS3j9.gif","https://tenor.com/oiYCh48iyTh.gif","https://tenor.com/bTcoh.gif","https://tenor.com/S6qmBNRdCH.gif","https://tenor.com/nCHh5hwyPcI.gif","https://tenor.com/bMN9s.gif","https://tenor.com/bwkmD.gif","https://tenor.com/gfdsGLlB5Y.gif","https://tenor.com/ivXUO7b2W07.gif","https://tenor.com/kOlH9ACE9D3.gif","https://tenor.com/pq8lqxnCNLy.gif","https://tenor.com/b0AmV.gif","https://tenor.com/urSwnJP09Tg.gif","https://tenor.com/gi6LcoAkz4Y.gif","https://tenor.com/rl1BsC9JSgE.gif","https://tenor.com/keN3CuAE4E2.gif","https://tenor.com/kp4Nt5KHYdi.gif","https://tenor.com/bBLnh.gif","https://media1.giphy.com/media/v1.Y2lkPTc5MGI3NjExbWtzY2ltM3l5c3BzaTB4bHl5dmZsc3I1c3lqaHEwbzFjNHE3ZXE2NCZlcD12MV9pbnRlcm5hbF9naWZfYnlfaWQmY3Q9Zw/6U9d8xKkez8iY/giphy.gif","https://media1.giphy.com/media/v1.Y2lkPTc5MGI3NjExb3AwaTJnM2duaXp6enExazByZmJzdDY5OWZuZndmM2ExZjVtZHZpNCZlcD12MV9pbnRlcm5hbF9naWZfYnlfaWQmY3Q9Zw/Uiujny6Aqrg40/giphy.gif","https://media3.giphy.com/media/v1.Y2lkPTc5MGI3NjExY3Vseng1enh5MDIyZ2tyYW9tZzNkc3g1NTJncWZsZ2E0NWp0dms5NiZlcD12MV9pbnRlcm5hbF9naWZfYnlfaWQmY3Q9Zw/d0DdMCREQChi3jGymW/giphy.gif","https://media2.giphy.com/media/v1.Y2lkPTc5MGI3NjExaGo4OThoMmVwN3d6MW5wNnc3NzY1a2c4emg2cHpzcWdwMGZiYjlvciZlcD12MV9pbnRlcm5hbF9naWZfYnlfaWQmY3Q9Zw/xcjE6k4xFEsHUqVbci/giphy.gif","https://media2.giphy.com/media/v1.Y2lkPTc5MGI3NjExcjk1dWg4YXppc3preGhoZjhoZnNzdWFuZ2F5ZWk2aXRmajRlM3FiciZlcD12MV9pbnRlcm5hbF9naWZfYnlfaWQmY3Q9Zw/VBVY9IJKDxwHK/giphy.gif","https://tenor.com/bQEJt.gif","https://tenor.com/bOozC.gif","https://tenor.com/M45a.gif","https://tenor.com/bPi6W.gif",
"https://raw.githubusercontent.com/KeanuCheese/MeetKeanu_Official_web/331217d9b7b52029156bf347cd579c8c91c2e993/Purple%20Beetle%20Girl.webp","https://raw.githubusercontent.com/KeanuCheese/MeetKeanu_Official_web/331217d9b7b52029156bf347cd579c8c91c2e993/Monarch%20Girl.webp","https://raw.githubusercontent.com/KeanuCheese/MeetKeanu_Official_web/331217d9b7b52029156bf347cd579c8c91c2e993/green_army_man.webp","https://raw.githubusercontent.com/KeanuCheese/MeetKeanu_Official_web/331217d9b7b52029156bf347cd579c8c91c2e993/stamp.webp"
];
const intro=document.getElementById('intro'), os=document.getElementById('os'), cta=document.getElementById('cta'), trail=document.getElementById('trail');
let bag=[],last="",spawnAt=0;
function refill(){bag=[...TRAIL_GIFS].sort(()=>Math.random()-.5)}
function pick(){if(!bag.length)refill();let v=bag.pop();if(v===last&&bag.length)v=bag.pop();last=v;return v}
refill();
addEventListener('mousemove',e=>{if(intro.style.display==='none')return;cta.style.left=e.clientX+'px';cta.style.top=e.clientY+'px';cta.classList.add('on');if(performance.now()-spawnAt<300)return;spawnAt=performance.now();const im=new Image();im.className='trailItem';im.src=pick();im.style.left=e.clientX+'px';im.style.top=e.clientY+'px';im.style.setProperty('--r',`${Math.floor(Math.random()*46-23)}deg`);trail.appendChild(im);while(trail.children.length>180)trail.removeChild(trail.firstChild)});
function showOS(){intro.style.display='none';cta.style.display='none';os.classList.add('on');openApp('about')}
document.getElementById('introCard').addEventListener('click',showOS);
document.getElementById('introCard').addEventListener('keydown',e=>{if(e.key==='Enter'||e.key===' '){e.preventDefault();showOS();}});

const audioCtx = new (window.AudioContext||window.webkitAudioContext)();
function sound(type='open'){const gain=audioCtx.createGain();gain.gain.value=0.015;const o=audioCtx.createOscillator();o.type='square';o.frequency.value={open:660,close:240,min:320,error:170}[type]||520;o.connect(gain).connect(audioCtx.destination);o.start();o.stop(audioCtx.currentTime+0.06)}

const modules={
  about:{title:'about.txt',icon:'📝',html:`<div class='panel'><b>KeanuOS</b><p>Sistema renovado: doble click real, start funcional, ventanas optimizadas, multimedia/collabs y visores embebidos.</p></div>`},
  documents:{title:'Documents',icon:'📄',html:`<div class='panel'>Documentos del sistema listos.</div>`},
  run:{title:'Run…',icon:'🏃',html:`<div class='panel'><div>Escribe un destino:</div><input id='runInput' style='width:100%;margin:8px 0;padding:6px' placeholder='https://... o app://about'><button id='runGo'>Abrir</button></div>`},
  programs:{title:'Programs',icon:'📂',html:`<div class='panel'>Submenú Programs habilitado (visual Win95 ▶).</div>`},
  collabs:{title:'Collabs',icon:'🤝',type:'folder',items:[
    {icon:'🌐',name:'Amazonic',url:'https://amazonicwav.tumblr.com/'},
    {icon:'🛍️',name:'Loot apparel boutique',url:'https://www.etsy.com/shop/LootApparelBoutique?ref=dashboard-header'}
  ]},
  multimedia:{title:'Multimedia',icon:'🎬',type:'folder',items:[
    {icon:'🎞️',name:'Basquiat_1996_JulianSchnabel',url:'https://www.youtube.com/watch?v=9D9AweGhI3c'},
    {icon:'🎞️',name:'La_Bella_Verte_1996_ColineSerreau',url:'https://odysee.com/@404whiterose:4/La-Belle-Verte-1996-%28The-Green-Beautiful%29-Dvdrip-X264-Highcode-1:b'},
    {icon:'🎞️',name:'CloudAtlas_2013_LanaWachowski_TomTykwer_LillyWachowski',url:'https://youtu.be/gTHgYkP_ksg?si=h8SkPasXsRMmh1Py'},
    {icon:'🧛',name:'Bride_of_Deimos_1988_Rintaro_byMadhouse',url:'https://youtu.be/KScaPWhZxmI?si=E_QQSK8grr-BVsQL'},
    {icon:'🧛',name:'Vampire_HunterD_Bloodlust_2000_YoshiakiKawajiri_byMadhause',url:'https://youtu.be/IIHnnI17joE?si=bX3nugK40jgKXtHf'},
    {icon:'🎬',name:'Estract_Chronos_1985_RonFricke',url:'https://www.youtube.com/watch?v=U-_DxBxDtVE'},
    {icon:'📕',name:'El_Principito_Antoine_de_SaintExupéry',url:'https://digitales.bcn.gob.ar/files/textos/El-Principitocompleto.pdf'}
  ]}
};

const desktopIcons=[
  {id:'about',label:'About',icon:'📝',x:18,y:18,open:()=>openApp('about')},
  {id:'collabs',label:'Collabs',icon:'🤝',x:18,y:112,open:()=>openFolder('collabs')},
  {id:'multimedia',label:'Multimedia',icon:'🎬',x:18,y:206,open:()=>openFolder('multimedia')},
  {id:'dali',label:'Dreams of Dali: 360',icon:'🎥',x:18,y:300,open:()=>openURLWindow('Dreams of Dali: 360','🎥','https://www.youtube.com/watch?v=F1eLeIocAcU&list=RDF1eLeIocAcU&start_radio=1')},
  {id:'stoken',label:'Quest for stoken',icon:'🪙',x:18,y:394,open:()=>openURLWindow('Quest for stoken','🪙','https://quest-for-stoken.vercel.app/')}
];

let selected=null,z=30; const wins=new Map();
const iconsEl=document.getElementById('icons'),tasks=document.getElementById('tasks'),startBtn=document.getElementById('startBtn'),startMenu=document.getElementById('startMenu');
function mkWindow(id,title,icon,html){
  if(wins.has(id)){const w=wins.get(id);w.el.style.display='flex';focus(w);return w.el}
  const el=document.createElement('div');el.className='win';el.dataset.id=id;el.style.left=(90+Math.random()*140)+'px';el.style.top=(60+Math.random()*90)+'px';
  el.innerHTML=`<div class='head'><div class='title'><span>${icon}</span><span>${title}</span></div><div class='btns'><div class='btn' data-a='min'>_</div><div class='btn' data-a='max'>□</div><div class='btn' data-a='close'>×</div></div></div><div class='body'>${html}</div>`;
  document.getElementById('desktop').appendChild(el);
  const task=document.createElement('div');task.className='task active';task.textContent=title;tasks.appendChild(task);
  const state={el,task};wins.set(id,state);focus(state);sound('open');
  task.onclick=()=>{if(el.style.display==='none'){el.style.display='flex';focus(state)}else if(task.classList.contains('active')){el.style.display='none';task.classList.remove('active')}else focus(state)};
  el.addEventListener('mousedown',()=>focus(state));
  const head=el.querySelector('.head');let drag=false,sx=0,sy=0,ox=0,oy=0;
  head.onmousedown=e=>{if(el.classList.contains('max'))return;drag=true;sx=e.clientX;sy=e.clientY;const r=el.getBoundingClientRect();ox=r.left;oy=r.top};
  addEventListener('mousemove',e=>{if(!drag)return;el.style.left=Math.max(4,Math.min(innerWidth-el.offsetWidth-4,ox+e.clientX-sx))+'px';el.style.top=Math.max(4,Math.min(innerHeight-el.offsetHeight-46,oy+e.clientY-sy))+'px'},{passive:true});
  addEventListener('mouseup',()=>drag=false);
  head.onclick=e=>{const b=e.target.closest('.btn');if(!b)return;const a=b.dataset.a;if(a==='min'){el.style.display='none';task.classList.remove('active');sound('min')}if(a==='max'){el.classList.toggle('max');b.textContent=el.classList.contains('max')?'❐':'□'}if(a==='close'){el.remove();task.remove();wins.delete(id);sound('close')}};
  head.ondblclick=()=>{const b=head.querySelector('[data-a=max]');b.click();};
  return el;
}
function focus(state){z++;state.el.style.zIndex=z;document.querySelectorAll('.task').forEach(t=>t.classList.remove('active'));state.task.classList.add('active')}
function openApp(id){const m=modules[id];if(!m)return sound('error');const w=mkWindow(id,m.title,m.icon,m.html);if(id==='run'){const i=w.querySelector('#runInput');const g=w.querySelector('#runGo');g.onclick=()=>{const v=i.value.trim();if(!v)return; if(v.startsWith('app://'))openApp(v.replace('app://','')); else openURLWindow(v,'🌐',v);};}}
function urlToEmbed(url){
  try{const u=new URL(url);if(u.hostname.includes('youtube.com')||u.hostname.includes('youtu.be')){let vid='';if(u.hostname.includes('youtu.be'))vid=u.pathname.slice(1);else vid=u.searchParams.get('v');if(vid)return `https://www.youtube.com/embed/${vid}?autoplay=0&rel=0`}
    if(u.hostname.includes('odysee.com')){return `https://odysee.com/$/embed${u.pathname}${u.search}`}
    if(url.toLowerCase().endsWith('.pdf')) return url;
  }catch{}
  return url;
}
function openURLWindow(title,icon,url){const embed=urlToEmbed(url);const isPdf=url.toLowerCase().includes('.pdf');mkWindow('url:'+title,title,icon,`<div class='panel' style='height:100%;display:flex;flex-direction:column;gap:8px'><div class='tiny'>${url}</div><iframe class='embed' src='${embed}' allow='autoplay; fullscreen; encrypted-media; picture-in-picture' referrerpolicy='no-referrer' loading='lazy'></iframe>${isPdf?"<div class='tiny'>PDF visible dentro del sistema.</div>":''}</div>`)}
function openFolder(id){const f=modules[id];if(!f)return;const html=`<div class='panel'><div class='folderGrid'>${f.items.map((it,ix)=>`<div class='entry' data-i='${ix}'><div>${it.icon}</div><div><b>${it.name}</b><div class='tiny'>Abrir en ventana del sistema</div></div></div>`).join('')}</div></div>`;const w=mkWindow(id,f.title,f.icon,html);w.querySelectorAll('.entry').forEach(e=>e.onclick=()=>{const it=f.items[+e.dataset.i];openURLWindow(it.name,it.icon,it.url)});
}

function renderIcons(){iconsEl.innerHTML='';desktopIcons.forEach(ic=>{const el=document.createElement('div');el.className='deskIcon';el.style.left=ic.x+'px';el.style.top=ic.y+'px';el.innerHTML=`<div class='box'>${ic.icon}</div><div class='lbl'>${ic.label}</div>`;let drag=false,dx=0,dy=0,moved=false;el.addEventListener('click',e=>{e.stopPropagation();document.querySelectorAll('.deskIcon').forEach(d=>d.classList.remove('sel'));el.classList.add('sel');selected=el;});el.addEventListener('dblclick',e=>{e.stopPropagation();ic.open();});el.addEventListener('pointerdown',e=>{if(e.button!==0)return;drag=true;moved=false;const r=el.getBoundingClientRect();dx=e.clientX-r.left;dy=e.clientY-r.top;el.setPointerCapture(e.pointerId)});el.addEventListener('pointermove',e=>{if(!drag)return;moved=true;const nx=Math.max(4,Math.min(innerWidth-el.offsetWidth-4,e.clientX-dx));const ny=Math.max(4,Math.min(innerHeight-el.offsetHeight-52,e.clientY-dy));el.style.left=nx+'px';el.style.top=ny+'px'});el.addEventListener('pointerup',()=>{drag=false;ic.x=parseInt(el.style.left)||ic.x;ic.y=parseInt(el.style.top)||ic.y;});iconsEl.appendChild(el);});}
renderIcons();
addEventListener('click',()=>{document.querySelectorAll('.deskIcon').forEach(d=>d.classList.remove('sel'));startMenu.classList.remove('on')});

startBtn.onclick=e=>{e.stopPropagation();startMenu.classList.toggle('on')};
startMenu.onclick=e=>{const item=e.target.closest('.menuItem');if(!item)return;startMenu.classList.remove('on');const act=item.dataset.open;
  if(act==='shutdown'){os.classList.remove('on');intro.style.display='flex';cta.style.display='block';sound('close');return;}
  if(act==='discord'){window.open('https://discord.com/users/849764011670110250','_blank','noopener');return;}
  if(act==='tumblr')return openURLWindow('Tumblr','🌀','https://dadaisnothingmeh.tumblr.com/');
  if(act==='skatehive')return openURLWindow('Skatehive','🛹','https://skatehive.app/user/keanucheese?view=snaps');
  if(['programs','documents','run'].includes(act))return openApp(act);
};

